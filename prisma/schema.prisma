// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ADMIN & AUTH ─────────────────────────────────────────────────────────────

model Admin {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  passwordHash  String    @map("password_hash")
  role          AdminRole @default(ADMIN)
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions Session[]

  @@map("admins")
}

model Session {
  id        String   @id @default(uuid())
  adminId   String   @map("admin_id")
  tokenHash String   @map("token_hash") @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@map("sessions")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

// ─── CONTENT MODELS ───────────────────────────────────────────────────────────

model Project {
  id          String          @id @default(uuid())
  title       String          @db.VarChar(255)
  slug        String          @unique @db.VarChar(255)
  categoryId  String          @map("category_id")
  year        Int
  location    String          @db.VarChar(255)
  area        String          @db.VarChar(100)
  description String          @db.Text
  coverImage  String          @map("cover_image") @db.VarChar(500)
  images      Json            @default("[]")
  isPublished Boolean         @default(false) @map("is_published")
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  category    ProjectCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([isPublished])
  @@index([sortOrder])
  @@map("projects")
}

model ProjectCategory {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  projects    Project[]

  @@map("project_categories")
}

model NewsCategory {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  news        News[]

  @@map("news_categories")
}

model News {
  id          String       @id @default(uuid())
  title       String       @db.VarChar(255)
  slug        String       @unique @db.VarChar(255)
  categoryId  String       @map("category_id")
  content     String       @db.Text
  coverImage  String       @map("cover_image") @db.VarChar(500)
  isPublished Boolean      @default(false) @map("is_published")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  category    NewsCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([isPublished])
  @@map("news")
}

model Testimonial {
  id          String   @id @default(uuid())
  quote       String   @db.Text
  name        String   @db.VarChar(255)
  role        String   @db.VarChar(255)
  project     String   @db.VarChar(255)
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@map("testimonials")
}

model Service {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String   @db.Text
  icon        String   @db.VarChar(50)
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@map("services")
}

model TeamMember {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  role        String   @db.VarChar(255)
  image       String   @db.VarChar(500)
  isPublished Boolean  @default(false) @map("is_published")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@map("team_members")
}

model SiteSetting {
  id        String          @id @default(uuid())
  key       String          @unique @db.VarChar(100)
  value     String          @db.Text
  type      SettingType     @default(STRING)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("site_settings")
}

enum SettingType {
  STRING
  NUMBER
  JSON
  BOOLEAN
}

model ContactSubmission {
  id        String        @id @default(uuid())
  name      String        @db.VarChar(255)
  email     String        @db.VarChar(255)
  phone     String?       @db.VarChar(50)
  message   String        @db.Text
  budget    String?       @db.VarChar(100)
  status    ContactStatus @default(UNREAD)
  readAt    DateTime?     @map("read_at")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

enum ContactStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

model PageView {
  id        String   @id @default(uuid())
  path      String   @db.VarChar(255)
  ip        String?  @db.VarChar(45)
  userAgent String?  @db.Text
  referrer  String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([path])
  @@map("page_views")
}
